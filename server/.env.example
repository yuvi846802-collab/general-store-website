# Connect to Postgres via the shared transaction-mode pooler
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# JWT Secret - MUST be a long random string in production
JWT_SECRET="replace-with-a-strong-random-secret-min-64-chars"

# JWT Token Expiry
JWT_EXPIRES_IN="15m"

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USERNAME="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="Store Name <your-email@gmail.com>"

# Server environment
NODE_ENV="development"
PORT="5000"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"
